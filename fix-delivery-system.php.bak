<?php
require_once 'includes/config.php';

echo "<h2>Adding Delivery & Satisfaction System</h2>";

// Add delivery related columns
$columns = [
    "delivery_status ENUM('pending_review', 'approved', 'rejected', 'revision_requested', 'delivered') DEFAULT 'pending_review'",
    "delivery_file VARCHAR(255) NULL",
    "delivered_at TIMESTAMP NULL",
    "client_approved_at TIMESTAMP NULL",
    "revision_notes TEXT NULL",
    "revision_count INT DEFAULT 0",
    "client_feedback TEXT NULL",
    "satisfaction_rating INT NULL"
];

foreach ($columns as $column) {
    $sql = "ALTER TABLE commissions ADD COLUMN IF NOT EXISTS $column";
    if (mysqli_query($conn, $sql)) {
        echo "✅ Added column: " . substr($column, 0, 50) . "...<br>";
    } else {
        echo "❌ Error: " . mysqli_error($conn) . "<br>";
    }
}

echo "<hr>";
echo "<p style='color:green;'>✅ Delivery system ready!</p>";
echo "<p><a href='commission-details.php?id=1'>Test it</a></p>";
echo "<p style='color:red;'><strong>⚠️ DELETE THIS FILE AFTER RUNNING!</strong></p>";
?>